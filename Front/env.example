# Configuração de Variáveis de Ambiente
# Copie este arquivo para .env.local e configure suas variáveis

# URL da API Backend
# Altere para a URL onde seu backend está rodando
NEXT_PUBLIC_API_URL=http://10.230.254.238:3500

# Exemplos de configuração:

# Desenvolvimento local (backend na porta 3500)
# NEXT_PUBLIC_API_URL=http://localhost:3500

# Desenvolvimento local (backend na porta 3000)
# NEXT_PUBLIC_API_URL=http://localhost:3000

# Produção
# NEXT_PUBLIC_API_URL=https://api.seudominio.com.br

# Ambiente de staging/testes
# NEXT_PUBLIC_API_URL=https://staging-api.seudominio.com.br
